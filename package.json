{
  "name": "clientdocs",
  "version": "1.0.0",
  "description": "secure client document manager",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "db:generate": "prisma generate --schema src/database/schema/prisma.schema",
    "db:migrate": "prisma migrate dev --schema src/database/schema/prisma.schema",
    "db:push": "prisma db push --schema src/database/schema/prisma.schema",
    "db:studio": "prisma studio --schema src/database/schema/prisma.schema",
    "db:seed": "tsx src/database/seeds/seed-users.ts",
    "auth:sessions:cleanup": "tsx src/server/features/auth/infrastructure/cleanup-auth-sessions.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.2.4",
    "pdfjs-dist": "^5.6.205",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.0.2",
    "prisma": "^6.16.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "prisma": {
    "seed": "npm run db:seed"
  }
}
